# ─────────────────────────────────────────────────────────────────────────────
# ERP OS — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
DEMO_MODE=false
APP_VERSION=0.1.0

# ── Security (generate with: openssl rand -hex 32) ───────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── Database ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=erp_os
MYSQL_USER=root
MYSQL_PASSWORD=123456

# SQLAlchemy async URL (uses same credentials above)
DATABASE_URL=mysql+aiomysql://root:123456@mysql:3306/erp_os
DATABASE_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── AI / Anthropic ────────────────────────────────────────────────────────────
AI_ENABLED=false
ANTHROPIC_API_KEY=
# OCR (PO invoice extraction) — separate timeout because Vision calls take longer
AI_OCR_MODEL=claude-sonnet-4-6
AI_OCR_TIMEOUT_SECONDS=30
AI_OCR_DAILY_QUOTA=20
AI_OCR_MAX_FILE_MB=10

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# ── Celery ────────────────────────────────────────────────────────────────────
# Leave blank to use Redis defaults (auto-built from REDIS_* above)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Inventory / Goods Receipt ─────────────────────────────────────────────────
# Allowed over-receipt tolerance as a fraction (0–1).
# 0    = strict reject (qty_received must equal remaining)
# 0.05 = 5% tolerance (default, ISO 9001 industry norm for packaging rounding)
GR_OVER_RECEIPT_TOLERANCE=0.05
