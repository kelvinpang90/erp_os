# ERP vhost 模板（部署到 VPS 后复制为 erp.conf，把 erp.example.com 改成真实域名）

server {
    listen 80;
    server_name erp.example.com;
    return 301 https://$host$request_uri;
}

upstream erp_backend  { server erp_backend:8000; }
upstream erp_frontend { server erp_frontend:80; }

server {
    listen 443 ssl http2;
    server_name erp.example.com;

    ssl_certificate     /etc/nginx/certs/origin.crt;
    ssl_certificate_key /etc/nginx/certs/origin.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    client_max_body_size 25M;

    # 安全 header
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Health check
    location = /health {
        access_log off;
        proxy_pass http://erp_backend/health;
        proxy_set_header Host $host;
    }

    # API
    location /api/ {
        proxy_pass http://erp_backend/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_http_version 1.1;

        # SSE（OCR 流式进度）— 必须关 buffering
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # OpenAPI docs（生产建议加 IP 白名单或 basic auth；演示站点先放开）
    location ~ ^/(docs|redoc|openapi\.json) {
        proxy_pass http://erp_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
    }

    # 静态文件下发（受控文件接口）
    location /api/files/ {
        proxy_pass http://erp_backend/api/files/;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_buffering on;
    }

    # Frontend SPA（erp_frontend 是 nginx-static 镜像，已做 try_files 兜底）
    location / {
        proxy_pass http://erp_frontend/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
