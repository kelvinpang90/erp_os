# ─────────────────────────────────────────────────────────────────────────────
# ERP OS — 生产 / Demo 站点 env (docker-compose.prod.yml 用)
# 复制为 .env.production 填值，DO NOT COMMIT
# ─────────────────────────────────────────────────────────────────────────────

# ── Image registry (compose 变量替换用) ─────────────────────────────────────
# GHCR_OWNER 小写 GitHub owner（个人 / 组织名）
GHCR_OWNER=change_me_owner
IMAGE_TAG=latest

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
DEMO_MODE=true                          # demo 站点保持 true（72h → 72s）
APP_VERSION=0.1.0

# ── Security ────────────────────────────────────────────────────────────────
# 生成： openssl rand -hex 32
SECRET_KEY=CHANGE_ME

# 真实域名（与 nginx/conf.d/erp.conf 的 server_name 一致）
CORS_ORIGINS=https://erp.kelvinpeng.com

# ── Database (共享 infra_mysql) ──────────────────────────────────────────────
# 用 erp_app 账号（不是 root），host = vps_infra 栈里 mysql 的 service 名 infra_mysql
DATABASE_URL=mysql+aiomysql://erp_app:CHANGE_ME_erp_app_pwd@infra_mysql:3306/erp_os
DATABASE_ECHO=false

# ── Redis (共享 infra_redis) ─────────────────────────────────────────────────
# erp 项目占用 DB 5–11（避开 crm_os 已使用的 0–4）。
# 部署前务必核对 crm_os 实际占用的 DB 索引，按需调整。
REDIS_HOST=infra_redis
REDIS_PORT=6379
REDIS_PASSWORD=

REDIS_DB_DEFAULT=5
REDIS_DB_CACHE=6
REDIS_DB_AUTH=7
REDIS_DB_RATE=8

# Celery broker / result 独立占 DB，避免和 cache 互相 FLUSHDB
CELERY_BROKER_URL=redis://infra_redis:6379/10
CELERY_RESULT_BACKEND=redis://infra_redis:6379/11

# ── AI / Anthropic ───────────────────────────────────────────────────────────
AI_ENABLED=true
ANTHROPIC_API_KEY=CHANGE_ME
AI_OCR_MODEL=claude-sonnet-4-6
AI_OCR_TIMEOUT_SECONDS=30
AI_OCR_DAILY_QUOTA=20
AI_OCR_MAX_FILE_MB=10

# ── File Storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# ── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Inventory ───────────────────────────────────────────────────────────────
GR_OVER_RECEIPT_TOLERANCE=0.05

# ── e-Invoice / MyInvois ─────────────────────────────────────────────────────
MYINVOIS_MODE=mock
