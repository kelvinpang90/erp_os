# ─────────────────────────────────────────────────────────────────────────────
# ERP OS — 生产 / Demo 站点 env (docker-compose.prod.yml 用)
# 复制为 .env.production 填值，DO NOT COMMIT
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
DEMO_MODE=true                          # demo 站点保持 true（72h → 72s）
APP_VERSION=0.1.0

# ── Security ────────────────────────────────────────────────────────────────
# 生成： openssl rand -hex 32
SECRET_KEY=CHANGE_ME

# 真实域名
CORS_ORIGINS=https://erp.example.com

# ── Database (共享 infra_mysql) ──────────────────────────────────────────────
# 用 erp_app 用户（不是 root），host = 共享 mysql 的 service 名
DATABASE_URL=mysql+aiomysql://erp_app:CHANGE_ME_erp_app_pwd@mysql:3306/erp_os
DATABASE_ECHO=false

# ── Redis (共享 infra_redis) ─────────────────────────────────────────────────
# erp 项目分配 db 0-15
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Celery broker 用 db 0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── AI / Anthropic ───────────────────────────────────────────────────────────
AI_ENABLED=true
ANTHROPIC_API_KEY=CHANGE_ME
AI_OCR_MODEL=claude-sonnet-4-6
AI_OCR_TIMEOUT_SECONDS=30
AI_OCR_DAILY_QUOTA=20
AI_OCR_MAX_FILE_MB=10

# ── File Storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# ── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Inventory ───────────────────────────────────────────────────────────────
GR_OVER_RECEIPT_TOLERANCE=0.05
